# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local gallery media can be very large. Keep media files on storage/CDN,
# and commit only placeholders plus the gallery setup code.
public/gallery-media/images/*
!public/gallery-media/images/.gitkeep
public/gallery-media/videos/*
!public/gallery-media/videos/.gitkeep

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
